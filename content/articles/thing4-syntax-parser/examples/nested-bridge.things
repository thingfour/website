Bridge modbus:tcp:gateway "Main gateway" [ host="192.168.10.50", port=502, id=1 ] {

  Bridge poller inputs "Fast poller" [ start=0, length=8, refresh=1000, type="input" ] {
    Thing data temperature [ readStart="0", readValueType="int16" ]
    Thing data pressure [ readStart="1", readValueType="int16" ]
  }

  Bridge poller holding "Slow poller" [ start=20, length=6, refresh=5000, type="holding" ] {
    Thing data energy [ readStart="20", readValueType="uint32" ]
  }
}
